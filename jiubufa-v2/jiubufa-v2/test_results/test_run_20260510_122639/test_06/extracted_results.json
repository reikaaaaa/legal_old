    "key_content": {
      "裁判分析": {
        "争议焦点": [
          "夫妻感情是否确已破裂，是否应准予离婚",
          "婚生子抚养权归属及抚养费数额的确定",
          "涉案房产、银行存款及股票是否属于夫妻共同财产及具体分割方案",
          "原告主张的精神损害赔偿金是否具备事实与法律依据"
        ],
        "事实认定": {
          "婚姻及子女状况": "原被告于2018年10月登记结婚，2020年3月生育一子，婚姻关系合法有效。自2024年2月起双方分居，婚生子一直随原告生活。",
          "家庭暴力事实": "原告提交的公安机关告诫书、医院就诊记录、轻微伤鉴定意见、人身安全保护令裁定书及证人证言相互印证，形成完整证据链。被告虽抗辩系双方互殴，但未能提供反证，法院依法认定被告在婚姻存续期间多次对原告实施家庭暴力。",
          "财产性质认定": "涉案房产购于婚后，首付款中双方父母出资部分无明确约定仅赠与一方，依法视为对夫妻双方的赠与；婚后共同还贷部分及房屋增值属共同财产。被告名下50万元存款及30万元股票均系婚姻关系存续期间的工资收入及投资收益，依法认定为夫妻共同财产。被告主张15万元存款为婚前个人财产，因资金已发生混同且举证不能，不予采信。",
          "抚养条件评估": "双方均具备抚养能力。婚生子现年4岁，目前实际随原告生活，已形成稳定的生活环境。原告工作稳定，被告收入较高但主张的抚养优势不足以推翻“最有利于未成年子女”原则。"
        },
        "法律适用": [
          "《中华人民共和国民法典》第一千零七十九条（诉讼离婚及家庭暴力法定离婚情形）",
          "《中华人民共和国民法典》第一千零八十四条、第一千零八十五条（离婚后子女抚养及抚养费负担）",
          "《中华人民共和国民法典》第一千零六十二条、第一千零八十七条（夫妻共同财产认定及分割原则）",
          "《中华人民共和国民法典》第一千零九十一条（离婚损害赔偿）",
          "《最高人民法院关于适用〈中华人民共和国民法典〉婚姻家庭编的解释（一）》第二十九条（父母出资购房性质认定）"
        ],
        "裁判理由": {
          "关于离婚请求": "被告实施家庭暴力，严重伤害夫妻感情，且双方已分居，调解无效，符合《民法典》第1079条规定的“感情确已破裂”法定情形，依法应准予离婚。被告关于感情未破裂的抗辩不予采纳。",
          "关于子女抚养": "遵循最有利于未成年子女原则。婚生子年幼且长期随原告生活，改变生活环境不利于其身心健康。原告主张抚养权于法有据，予以支持。结合被告月收入15000元及当地实际生活水平，原告主张每月3000元抚养费比例适当（约占被告月收入20%），予以支持。",
          "关于财产分割": "涉案房产现值200万元，尚欠贷款80万元，净值为120万元；存款50万元与股票30万元合计80万元。上述财产均属夫妻共同财产。鉴于被告存在家庭暴力重大过错，根据《民法典》第1087条照顾无过错方及女方权益的原则，原告在财产分割中应适当多分。综合考量，法院酌定原告分得共同财产净值的60%，被告分得40%。为便于执行及保障子女居住稳定，房产判归原告所有，剩余贷款由原告承担；存款及股票判归被告所有。经折价抵算后，由被告向原告支付财产折价补偿款。",
          "关于损害赔偿": "被告实施家庭暴力系导致离婚的直接原因，原告作为无过错方有权请求损害赔偿。结合暴力频次、损害后果（轻微伤）及当地经济水平，原告主张50000元精神损害赔偿金未超出合理范围，依法予以支持。"
        },
        "裁判结果": [
          "准予原告张某与被告李某离婚。",
          "婚生子李某某由原告张某直接抚养，被告李某自本判决生效之月起，每月15日前支付抚养费人民币3000元，至李某某年满十八周岁止。",
          "位于某某市某某区某某路XX号房产归原告张某所有，该房产剩余按揭贷款由原告张某负责偿还；被告李某名下银行存款50万元及股票账户资产归被告李某所有。被告李某于本判决生效之日起三十日内向原告张某支付财产折价补偿款人民币240000元。",
          "被告李某于本判决生效之日起三十日内向原告张某支付精神损害赔偿金人民币50000元。",
          "驳回原告张某的其他诉讼请求。"
        ],
        "诉讼费承担": "案件受理费依法减半收取，由原告张某负担30%，被告李某负担70%（因被告存在家庭暴力过错导致诉讼）。",
        "裁判要旨": "在离婚纠纷中，一方实施家庭暴力经公安机关告诫、伤情鉴定及人身安全保护令等证据证实的，应依法认定夫妻感情确已破裂并准予离婚。财产分割应贯彻照顾无过错方原则，对施暴方予以少分；无过错方据此主张离婚损害赔偿的，人民法院应予支持。子女抚养权归属应以最有利于未成年子女健康成长为核心考量，实际抚养状况及生活环境稳定性是重要裁判依据。"
      }
    }
  },
