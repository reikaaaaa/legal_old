      "case_id": "case-2024-marriage-0001",
      "裁判分析": {
        "争议焦点": [
          "夫妻感情是否确已破裂及是否准予离婚",
          "婚生子抚养权归属及抚养费数额的确定",
          "涉案房产、存款、股票等财产的性质认定及分割方案",
          "家庭暴力事实是否成立及精神损害赔偿请求是否应予支持"
        ],
        "事实认定与证据采信": {
          "婚姻关系及子女情况": "双方于2018年登记结婚，2020年育有一子，事实清楚，证据充分，予以确认。",
          "家庭暴力事实": "原告提交的公安机关告诫书、医院就诊记录、轻微伤鉴定意见、人身安全保护令裁定书及证人证言形成完整证据链。被告虽辩称系双方互殴，但未能提供反证推翻公文书证及鉴定意见的证明力。法院依法认定被告实施家庭暴力的事实成立。",
          "分居事实": "原告自2024年2月起携子搬离并实际抚养，有租赁合同及居委会证明佐证，被告予以承认，法院予以确认。",
          "财产状况": "涉案房产购买于婚后，首付款含双方父母出资及共同存款，无明确约定仅赠与一方，依法推定为对夫妻双方的赠与；银行存款及股票账户资金均形成于婚姻关系存续期间，被告主张部分属个人财产但资金已混同且未能举证证明明确归属，法院依法认定为夫妻共同财产。双方对财产现值及债务金额无异议，予以确认。"
        },
        "法律适用与裁判理由": {
          "离婚请求": "依据《民法典》第1079条，实施家庭暴力调解无效的，应当准予离婚。本案被告存在家暴行为，且双方已分居，夫妻感情确已破裂，无和好可能，故对原告离婚诉请予以支持。",
          "子女抚养": "依据《民法典》第1084条，已满两周岁子女抚养权按最有利于未成年子女原则判决。婚生子现年4岁，原告自分居起一直实际抚养，生活学习环境稳定，且具备抚养能力。被告虽收入较高，但并非决定抚养权的唯一因素。为维持子女成长环境稳定，抚养权判归原告更为适宜。",
          "抚养费": "依据《民法典》第1085条及最高人民法院相关司法解释，抚养费一般按月总收入20%-30%比例确定。被告月收入1.5万元，原告主张3000元/月（占比20%）符合法律规定及当地生活水平，予以支持。",
          "财产分割": "依据《民法典》第1062条、第1087条，夫妻共同财产原则上均等分割。房产净值120万元（现值200万-贷款80万），原告主张分得60万元符合均分原则；存款50万元、股票30万元亦按50%比例分割。考虑到房产登记在被告名下且由被告继续还贷，判令房产归被告所有，被告向原告支付房屋折价补偿款60万元，并承担剩余贷款。存款及股票按份额分割或折价补偿。",
          "损害赔偿": "依据《民法典》第1091条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。本案家暴事实成立，原告作为无过错方主张5万元精神损害赔偿，结合伤情程度及过错情节，数额合理，予以支持。"
        },
        "裁判结果预测": {
          "判决主文": [
            "准予原告张某与被告李某离婚。",
            "婚生子李某某由原告张某直接抚养，被告李某自判决生效次月起每月支付抚养费3000元，至李某某年满十八周岁止。",
            "位于某某市某某区某某路XX号房产归被告李某所有，剩余按揭贷款80万元由被告李某负责偿还；被告李某于本判决生效之日起三十日内向原告张某支付房屋折价补偿款60万元。",
            "被告李某名下银行存款50万元，双方各分得25万元；股票账户市值30万元，双方各分得15万元（具体由双方协商折价或变现分割，协商不成由法院依法处置）。",
            "被告李某于本判决生效之日起十日内向原告张某支付精神损害赔偿金5万元。",
            "案件受理费由原、被告各半承担。"
          ],
          "支持率评估": "原告四项诉讼请求均具有充分的事实与法律依据，预计法院支持率接近100%。被告抗辩理由因证据不足或与法律规定不符，预计不予采纳。"
        },
        "裁判要旨": "在离婚纠纷中，公安机关告诫书、伤情鉴定及人身安全保护令等公文书证与医疗记录相互印证，足以认定家庭暴力事实，构成法定离婚事由及损害赔偿基础。婚后父母出资购房无明确约定的，推定为对夫妻双方的赠与，属共同财产。子女抚养权归属应以“最有利于未成年子女”为原则，综合考量实际抚养状况、成长环境稳定性及父母抚养条件，而非单纯以经济收入高低为标准。"
      }
    }
  },
