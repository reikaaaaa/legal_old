      "judge_analysis": {
        "争议焦点": [
          "夫妻感情是否确已破裂及是否准予离婚",
          "婚生子抚养权归属及抚养费数额标准",
          "夫妻共同财产的范围认定与分割比例",
          "家庭暴力事实是否成立及离婚损害赔偿请求是否支持"
        ],
        "事实认定与证据采信": {
          "婚姻及子女事实": "双方于2018年登记结婚，2020年生育一子，事实清楚，证据（结婚证、出生医学证明）经质证无异议，予以确认。",
          "家庭暴力事实": "原告提交的公安机关告诫书、医院就诊记录、伤情鉴定意见书（轻微伤）及法院已生效的人身安全保护令裁定书形成完整证据链，证明力高度盖然。被告虽辩称系互殴且已道歉，但未能提供反证推翻公文书证及鉴定意见，其抗辩不予采信。依法认定被告存在家庭暴力行为。",
          "财产状况": "涉案房产购于婚后，虽登记在被告名下且双方父母有出资，但无书面约定明确仅赠与一方，依司法解释应推定为对夫妻双方的赠与，属夫妻共同财产。房产现值200万元，扣除剩余贷款80万元，净值为120万元。被告名下存款50万元及股票市值30万元均系婚后取得，被告主张部分属婚前个人财产或独立投资收益，但未能证明资金独立未发生混同，依法均认定为夫妻共同财产。共同财产总额为200万元。",
          "抚养条件": "婚生子现年4岁，自2024年2月起随原告生活，已形成稳定的生活与教育环境。原告有固定收入（月8000元）及抚养能力。被告虽收入较高（月15000元）且父母可协助，但改变子女现有生活环境不利于其身心健康成长。"
        },
        "法律适用与裁判说理": {
          "离婚请求": "依据《民法典》第1079条，实施家庭暴力调解无效的，应当准予离婚。本案家暴事实清楚，且双方已分居，夫妻感情确已破裂，无和好可能，依法支持原告离婚诉请。",
          "抚养权与抚养费": "依据《民法典》第1084条，离婚后子女抚养应按照最有利于未成年子女的原则判决。原告系主要照顾者，维持现状符合子女利益，抚养权归原告。依据《民法典》第1085条及司法解释，抚养费一般为不直接抚养方月总收入的20%-30%。被告月收入1.5万元，原告主张3000元/月（占比20%）符合法定比例及当地实际生活水平，予以全额支持。",
          "财产分割": "依据《民法典》第1062条、第1087条，夫妻共同财产原则上均等分割，但应照顾子女、女方和无过错方权益。鉴于被告存在家暴法定过错，在分割共同财产时依法对原告予以适当倾斜。综合考量，按原告55%、被告45%比例分割共同财产。房产归被告所有（便于其继续还贷及居住），被告承担剩余80万元贷款，并向原告支付房屋折价补偿款66万元（120万×55%）；存款及股票共计80万元，原告分得44万元，被告分得36万元。",
          "损害赔偿": "依据《民法典》第1091条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。原告作为无过错方，身心遭受伤害，主张精神损害赔偿于法有据。结合家暴频次、伤情程度（轻微伤）、过错程度及本地司法实践，酌定支持30000元。"
        },
