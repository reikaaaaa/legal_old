      "case_name": "张某诉李某离婚纠纷案",
      "judge_analysis": {
        "overall_conclusion": "夫妻感情确已破裂，准予离婚。原告关于子女抚养、财产分割及离婚损害赔偿的诉讼请求基本成立，依法予以支持。",
        "fact_confirmation": [
          "原被告于2018年10月登记结婚，2020年3月生育一子，婚姻关系合法有效。",
          "被告在婚姻存续期间多次对原告实施殴打，公安机关已出具告诫书，法院已签发人身安全保护令，伤情鉴定为轻微伤，家庭暴力事实成立。",
          "双方自2024年2月起分居，婚生子一直随原告共同生活。",
          "涉案房产购于婚后，登记在被告名下，尚有贷款80万元，现值200万元；被告名下存款50万元、股票市值30万元均形成于婚姻关系存续期间。",
          "原告月收入8000元，被告月收入15000元，双方均具备抚养能力。"
        ],
        "evidence_assessment": {
          "domestic_violence_evidence": "原告提交的公安机关告诫书、医院就诊记录、伤情鉴定意见书及人身安全保护令裁定书相互印证，形成完整证据链，证明力高。被告虽对关联性提出异议，但未能提供反证推翻，本院对家暴事实予以确认。",
          "property_evidence": "原告提交的房屋买卖合同、银行流水、证券账户明细等足以证明财产范围及价值。被告主张15万元存款系婚前个人财产、15万元购房款系父母对其个人赠与，但未能提供资金特定化流转凭证或明确赠与一方的书面约定，依法承担举证不能的不利后果，上述财产均认定为夫妻共同财产。",
          "custody_evidence": "双方收入证明、租赁合同及居委会证明客观真实，足以反映原告已实际抚养子女数月，生活环境稳定。"
        },
        "claim_adjudication": [
          {
            "claim_id": "c1",
            "claim_text": "判决离婚",
            "adjudication_result": "支持",
            "reasoning": "根据《民法典》第1079条，实施家庭暴力调解无效的，应当准予离婚。本案家暴事实清楚，且双方已分居，夫妻感情确已破裂，无和好可能，依法准予离婚。"
          },
          {
            "claim_id": "c2",
            "claim_text": "子女抚养权归原告，被告每月支付抚养费3000元",
            "adjudication_result": "支持",
            "reasoning": "婚生子现年4周岁，根据《民法典》第1084条及最有利于未成年子女原则，原告长期实际抚养，维持现有生活环境有利于子女身心健康成长。被告月收入15000元，原告主张3000元/月（约占被告月收入20%）符合《最高人民法院关于适用〈民法典〉婚姻家庭编的解释（一）》第49条规定的抚养费比例标准，予以支持。"
          },
          {
            "claim_id": "c3",
            "claim_text": "分割夫妻共同财产（房产、存款、股票）",
            "adjudication_result": "部分支持（依法均分）",
            "reasoning": "涉案房产、存款、股票均系婚后取得，依法属夫妻共同财产。父母出资购房无明确约定视为对夫妻双方的赠与。房产净值120万元（200万-80万），存款50万元，股票30万元，共同财产总额200万元。原则上各分得50%。考虑到房产登记在被告名下且由被告继续还贷，判令房产归被告所有，剩余贷款由被告承担，被告需向原告支付房屋折价补偿款60万元；存款及股票依法均分，被告需另行向原告支付折价款20万元。"
          },
          {
            "claim_id": "c4",
            "claim_text": "支付精神损害赔偿金50000元",
            "adjudication_result": "支持",
            "reasoning": "根据《民法典》第1091条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。原告作为无过错方，因被告家暴行为遭受身心伤害，主张5万元精神损害赔偿数额适当，符合司法实践裁量标准，予以支持。"
          }
        ],
