    "key_content": {
      "case_id": "case-2024-marriage-0001",
      "judge_analysis": {
        "fact_finding_and_evidence_evaluation": {
          "marriage_and_child": "双方于2018年10月18日登记结婚，2020年3月15日生育一子李某某。该事实有结婚证、出生医学证明佐证，双方均无异议，本院予以确认。",
          "domestic_violence": "家暴事实成立。原告提交的公安机关告诫书（e3）、医院就诊记录及伤情照片（e4）、轻微伤鉴定意见（e5）及人身安全保护令裁定书（e6）形成完整证据链，相互印证。被告虽辩称系双方互有肢体冲突，但未能提供反证推翻公文书证及鉴定意见的证明力。结合证人证言（e7），足以认定被告在婚姻存续期间多次对原告实施家庭暴力。",
          "separation": "分居事实成立。自2024年2月起原告携子搬离共同住所，双方分居至今，有租赁合同及居委会证明（e8）佐证，被告予以承认。",
          "property_status": "涉案房产、银行存款50万元、股票市值30万元均系婚姻关系存续期间取得。被告主张父母出资15万元属个人财产，但未能提供明确约定仅赠与一方的证据，依法推定为对夫妻双方的赠与；被告主张15万元存款系婚前个人财产，但资金已发生混同，无法清晰区分，依法认定为夫妻共同财产。股票收益系婚内投资所得，依法属共同财产。",
          "child_care_condition": "婚生子现年4岁，分居后一直由原告实际照顾。原告月收入8000元，工作稳定，具备抚养能力；被告月收入15000元，经济条件较优，但非决定抚养权归属的唯一标准。"
        },
        "dispute_focus_and_legal_analysis": {
          "focus_1_divorce": "夫妻感情是否确已破裂。依据《民法典》第1079条，实施家庭暴力调解无效的，应当准予离婚。本案家暴事实清楚，且双方已分居，调解和好无望，感情确已破裂。",
          "focus_2_custody_and_support": "抚养权归属及抚养费标准。依据《民法典》第1084条，按照最有利于未成年子女原则判决。原告长期实际抚养，维持现有生活环境利于子女成长。抚养费3000元/月约占被告月收入20%，符合《最高人民法院关于适用〈民法典〉婚姻家庭编的解释（一）》第49条规定的比例范围及当地生活水平。",
          "focus_3_property_division": "夫妻共同财产范围及分割比例。依据《民法典》第1062条、第1087条，婚内所得财产原则上均等分割。房产净值120万元（现值200万-贷款80万），双方各占50%份额。考虑到房产登记在被告名下且由被告继续持有，判归被告所有，被告需向原告支付折价补偿款60万元并承担剩余债务。存款与股票按50%比例实物或折价分割。",
          "focus_4_damages": "离婚损害赔偿是否成立。依据《民法典》第1091条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。原告作为无过错方，主张5万元精神损害赔偿，结合暴力情节、伤情后果及司法实践，数额适当，予以支持。"
        },
        "claim_adjudication": {
          "c1_divorce": {
            "claim_text": "判决离婚",
            "court_decision": "支持",
            "reasoning": "被告实施家庭暴力，符合法定离婚条件，夫妻感情确已破裂，调解无效，依法准予离婚。"
          },
          "c2_custody_support": {
            "claim_text": "子女抚养权归原告，被告每月支付抚养费3000元",
            "court_decision": "支持",
            "reasoning": "基于最有利于未成年子女原则及原告实际抚养现状，抚养权判归原告。被告月收入15000元，每月支付3000元抚养费符合法律规定及子女实际需要。"
          },
          "c3_property_division": {
            "claim_text": "分割夫妻共同财产（房产折价60万、存款25万、股票15万）",
            "court_decision": "支持",
            "reasoning": "涉案财产均属夫妻共同财产。房产净值120万元，原告主张50%份额即60万元折价补偿于法有据；存款50万元、股票30万元依法各半分割，原告分得25万元、15万元。被告个人财产抗辩证据不足，不予采纳。"
          },
          "c4_damages": {
            "claim_text": "支付精神损害赔偿金50000元",
            "court_decision": "支持",
            "reasoning": "被告家暴行为系导致离婚的重大过错，原告作为无过错方依法享有损害赔偿请求权。5万元赔偿金额合理，予以全额支持。"
          }
        },
        "legal_basis": [
          "《中华人民共和国民法典》第一千零七十九条（诉讼离婚及法定离婚情形）",
