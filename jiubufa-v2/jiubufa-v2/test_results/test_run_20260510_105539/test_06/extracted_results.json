        "dispute_focus": [
          "夫妻感情是否确已破裂及是否准予离婚",
          "婚生子抚养权归属及抚养费数额的确定",
          "涉案房产、存款、股票是否属于夫妻共同财产及具体分割方案",
          "家庭暴力事实是否成立及精神损害赔偿请求是否应予支持"
        ],
        "fact_finding_and_evidence_adoption": {
          "marriage_status": "原被告于2018年10月登记结婚，婚姻关系合法有效，双方均无异议，本院予以确认。",
          "domestic_violence": "原告提交的公安机关告诫书、医院就诊记录、伤情鉴定意见书（轻微伤）、人身安全保护令裁定书及证人证言形成完整证据链。被告虽辩称系双方互有肢体冲突，但未能提供反证推翻公权力机关文书及专业鉴定结论。依据《最高人民法院关于适用〈中华人民共和国民法典〉婚姻家庭编的解释（一）》相关规定，本院认定被告实施家庭暴力事实成立。",
          "separation_status": "原告自2024年2月起携子搬离共同住所，双方分居事实清楚，被告予以承认，本院予以确认。",
          "property_nature": "涉案房产购买于婚后，首付款中双方父母出资部分在无明确书面约定仅赠与一方的情况下，依法视为对夫妻双方的赠与；被告名下50万元存款虽主张15万元系婚前财产，但资金已发生混同且未能提供清晰流向证明，依法认定为夫妻共同财产；股票账户30万元系婚姻关系存续期间的投资收益，依法属于夫妻共同财产。被告关于个人财产的抗辩缺乏事实与法律依据，本院不予采纳。",
          "child_care_status": "婚生子现年4岁，自分居以来一直由原告实际照顾抚养，原告工作稳定，具备抚养条件。"
        },
        "legal_reasoning": {
          "divorce_claim": "依据《中华人民共和国民法典》第一千零七十九条，实施家庭暴力或调解无效感情确已破裂的，应当准予离婚。本案被告存在家暴行为，且双方已分居，夫妻感情确已破裂，无和好可能，原告离婚诉请依法应予支持。",
          "custody_and_support_claim": "依据《民法典》第一千零八十四条，离婚后子女抚养应按照最有利于未成年子女的原则判决。婚生子年仅4岁，原告作为母亲且长期实际抚养，更有利于孩子身心健康成长。被告虽收入较高，但经济条件非唯一决定因素。抚养费方面，被告月收入15000元，原告主张3000元/月约占其月收入20%，符合《最高人民法院关于适用〈民法典〉婚姻家庭编的解释（一）》第四十九条规定的比例范围，且未超出合理限度，本院予以支持。",
          "property_division_claim": "依据《民法典》第一千零六十二条，夫妻对共同财产有平等处理权。涉案财产净值合计200万元（房产净值120万+存款50万+股票30万），原则上均等分割。考虑到房产登记在被告名下且由被告实际居住，为便于生活及执行，房产归被告所有，剩余贷款由被告承担。被告需就原告应得份额（房产60万+存款25万+股票15万=100万元）向原告支付折价补偿款。",
          "damage_compensation_claim": "依据《民法典》第一千零九十一条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。被告家暴行为对原告造成身心伤害，原告作为无过错方主张精神损害赔偿5万元，结合过错程度、损害后果及本地经济水平，数额合理，本院予以支持。"
        },
