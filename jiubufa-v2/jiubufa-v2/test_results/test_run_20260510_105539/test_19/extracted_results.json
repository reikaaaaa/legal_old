    "key_content": {
      "case_id": "case-2024-marriage-0001",
      "裁判分析": {
        "一、事实认定与证据采信": {
          "婚姻关系与子女情况": "原告提交的结婚证(e1)、出生医学证明(e2)经被告质证无异议，本院依法确认双方于2018年10月18日登记结婚，2020年3月15日生育一子李某某。",
          "家庭暴力事实": "原告提交的公安机关告诫书(e3)、医院就诊记录(e4)、伤情鉴定意见书(e5)、人身安全保护令裁定书(e6)及邻居证言(e7)形成完整证据链。被告虽辩称系“互有肢体冲突”，但未能提供反证推翻公安机关告诫书及伤情鉴定结论。结合保护令已生效的事实，本院依法认定被告在婚姻存续期间多次对原告实施家庭暴力，致原告轻微伤，家庭暴力事实成立。",
          "分居事实": "原告提交的房屋租赁合同及居委会证明(e8)经被告质证无异议，本院依法确认双方自2024年2月起分居，婚生子随原告共同生活至今。",
          "夫妻共同财产认定": "涉案房产(e9-e11)、银行存款(e12)、股票账户(e13)均系婚姻关系存续期间取得。被告主张父母出资15万元(e18)及婚前存款15万元(e19)属个人财产，但未能提供书面赠与合同明确约定仅归被告一方，亦未能证明婚前存款与婚后收入严格隔离未发生混同。根据《民法典》及相关司法解释，父母婚后出资及婚后投资收益原则上推定为夫妻共同财产。本院依法认定上述房产、存款50万元、股票30万元均属夫妻共同财产。"
        },
        "二、争议焦点与法律适用": {
          "焦点一：是否准予离婚": {
            "争议内容": "被告主张感情未破裂，不同意离婚。",
            "裁判理由": "根据《民法典》第1079条，实施家庭暴力调解无效的，应当准予离婚。本案被告实施家庭暴力事实清楚，且双方已分居，夫妻感情确已破裂，无和好可能。原告离婚诉请符合法定条件，本院予以支持。"
          },
          "焦点二：子女抚养权及抚养费": {
            "争议内容": "双方均主张抚养权，被告主张经济条件更优；原告主张3000元/月，被告主张1500元/月。",
            "裁判理由": "根据《民法典》第1084条“最有利于未成年子女”原则，被告存在家庭暴力行为，不利于子女身心健康及成长环境。原告自分居起实际抚养子女，具备稳定工作与抚养能力。故抚养权判归原告更为适宜。关于抚养费，被告月收入约15000元，原告主张3000元/月约占其月收入20%，符合司法实践20%-30%的合理区间，本院予以支持。"
          },
          "焦点三：夫妻共同财产分割": {
            "争议内容": "被告主张部分财产属个人财产，要求不按50%分割。",
            "裁判理由": "根据《民法典》第1062条、第1087条，夫妻共同财产原则上均等分割。涉案房产现值200万元，剩余贷款80万元，净值为120万元，双方各享有60万元份额；存款50万元、股票30万元均属共同财产，各分得25万元、15万元。考虑到房产登记在被告名下且由被告继续居住使用，判令房产归被告所有，剩余贷款由被告承担，被告需向原告支付房屋折价补偿款60万元。存款与股票依法平均分割。"
          },
          "焦点四：离婚损害赔偿": {
            "争议内容": "被告否认家暴，拒绝支付5万元精神损害赔偿。",
            "裁判理由": "根据《民法典》第1091条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。本案家暴事实成立，原告作为无过错方主张精神损害赔偿于法有据。结合暴力频次、伤情程度（轻微伤）及当地生活水平，5万元赔偿金额合理，本院予以支持。"
          }
        },
        "三、裁判结果": [
          "准予原告张某与被告李某离婚。",
          "婚生子李某某由原告张某直接抚养，被告李某自本判决生效次月起，每月15日前向原告支付抚养费人民币3000元，至李某某年满十八周岁止。",
          "位于某某市某某区某某路XX号房产归被告李某所有，该房产剩余按揭贷款80万元由被告李某负责偿还；被告李某于本判决生效之日起三十日内向原告张某支付房屋折价补偿款人民币60万元。",
          "被告李某名下银行存款50万元，双方各分得25万元；被告李某名下股票账户资产（市值约30万元），双方各分得15万元。被告李某应于本判决生效之日起三十日内将原告应得份额（合计40万元）支付至原告指定账户。",
          "被告李某于本判决生效之日起三十日内向原告张某支付离婚精神损害赔偿金人民币50000元。",
          "案件受理费由原、被告各半负担。"
        ],
        "四、适用法律条文": [
          "《中华人民共和国民法典》第一千零七十九条（离婚法定条件）",
          "《中华人民共和国民法典》第一千零八十四条（离婚后子女抚养）",
          "《中华人民共和国民法典》第一千零八十五条（抚养费负担）",
          "《中华人民共和国民法典》第一千零六十二条（夫妻共同财产）",
          "《中华人民共和国民法典》第一千零八十七条（离婚财产分割原则）",
          "《中华人民共和国民法典》第一千零九十一条（离婚损害赔偿）",
          "《最高人民法院关于适用〈中华人民共和国民法典〉婚姻家庭编的解释（一）》第二十九条（父母出资购房性质认定）"
        ],
        "五、法官裁判要旨与释明": "本案系典型的家暴型离婚纠纷。裁判核心在于严格贯彻《民法典》保护弱者、惩戒过错的立法精神。家庭暴力不仅是法定离婚事由，更是抚养权归属的否定性评价因素及财产分割、损害赔偿的考量依据。在财产分割中，坚持婚后所得共同制原则，对主张个人财产的一方课以严格的举证责任。抚养费数额的确定兼顾子女实际需要与父母负担能力。本判决旨在通过司法裁判明确行为边界，维护婚姻家庭秩序与未成年人合法权益。"
      }
    }
  },
