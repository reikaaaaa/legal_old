      "case_id": "case-2024-marriage-0001",
      "裁判分析": {
        "案件定性": "离婚纠纷（含子女抚养、财产分割及离婚损害赔偿）",
        "争议焦点": [
          "夫妻感情是否确已破裂，是否符合法定离婚条件",
          "婚生子抚养权应归何方，抚养费数额如何确定",
          "涉案房产、银行存款及股票账户资金的性质认定及分割方案",
          "被告行为是否构成家庭暴力，原告主张的精神损害赔偿是否成立"
        ],
        "事实认定与证据采信": {
          "家庭暴力事实": "采信原告提交的公安机关告诫书、医院就诊记录、伤情鉴定意见书（轻微伤）、人身安全保护令裁定书及邻居证人证言。上述证据来源合法、内容客观真实、相互印证，形成完整证据链，足以认定被告在婚姻存续期间多次对原告实施家庭暴力。被告虽抗辩系双方互殴，但未提交有效反证，其抗辩不予采纳。",
          "感情破裂事实": "基于家庭暴力事实及双方自2024年2月起分居至今的客观情况，结合庭审中双方对立情绪明显、调解无效，依法认定夫妻感情确已破裂，无和好可能。",
          "财产性质认定": "涉案房产系婚后购买，虽登记在被告名下且首付款含双方父母出资，但无证据证明父母出资系明确赠与一方，依法推定为对夫妻双方的赠与，属夫妻共同财产。被告名下50万元存款及30万元股票均系婚姻存续期间取得及投资收益，被告主张部分属婚前个人财产或个人投资收益，但资金已发生混同且未能提供明确约定或独立账户流水予以区分，举证不能，依法认定为夫妻共同财产。",
          "抚养条件认定": "婚生子现年4岁，原告自分居起实际承担主要抚养义务，生活环境稳定。双方均具备抚养能力，综合考量子女成长连续性、实际抚养状况及最有利于未成年子女原则，原告抚养更为适宜。"
        },
        "法律适用与裁判理由": {
          "离婚请求": "依据《中华人民共和国民法典》第一千零七十九条，实施家庭暴力调解无效的，应当准予离婚。本案家庭暴力事实清楚，感情确已破裂，依法支持原告离婚请求。",
          "子女抚养": "依据《民法典》第一千零八十四条及婚姻家庭编司法解释相关规定，离婚后不满八周岁子女抚养权由法院根据最有利于未成年子女原则判决。原告实际抚养且具备稳定工作与收入，判归原告。被告月收入15000元，原告主张3000元/月抚养费符合其负担能力及当地实际生活水平，予以支持。",
          "财产分割": "依据《民法典》第一千零六十二条，夫妻对共同财产有平等处理权。涉案房产净值120万元（现值200万-贷款80万），存款50万元，股票30万元，合计共同财产净值200万元。原则上均等分割，原告应分得100万元。考虑到房产登记在被告名下且由被告继续居住使用，判令房产归被告所有，剩余贷款由被告承担，被告向原告支付折价款100万元。",
          "损害赔偿": "依据《民法典》第一千零九十一条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。被告家暴行为对原告身心造成伤害，原告作为无过错方主张50000元精神损害赔偿，数额合理，依法予以支持。"
        },
        "裁判结果（判决主文）": [
          "准予原告张某与被告李某离婚。",
          "婚生子李某某由原告张某直接抚养，被告李某自本判决生效之日起每月支付抚养费人民币3000元，至李某某年满十八周岁止。",
          "位于某某市某某区某某路XX号房产归被告李某所有，该房产剩余按揭贷款80万元由被告李某负责偿还；被告李某于本判决生效之日起三十日内向原告张某支付夫妻共同财产折价款人民币1000000元。",
          "被告李某于本判决生效之日起十日内向原告张某支付离婚损害赔偿金人民币50000元。",
          "案件受理费、财产保全费及评估费由原、被告依法分担。"
        ],
        "法官释明与程序事项": "本判决为一审判决。如不服本判决，可在判决书送达之日起十五日内向本院递交上诉状。被告履行财产给付义务时，应通过银行转账等可追溯方式进行。如被告未按期履行金钱给付义务，原告可依法申请强制执行，被告将承担迟延履行期间的债务利息。本案已充分保障双方举证、质证及辩论权利，程序合法。"
      }
    }
