      "case_id": "case-2024-marriage-0001",
      "judgment_analysis": {
        "fact_finding": {
          "marriage_and_child": "双方于2018年10月18日登记结婚，2020年3月15日生育一子李某某，事实清楚，双方无异议，本院予以确认。",
          "domestic_violence": "2023年6月至2024年3月期间，被告多次对原告实施殴打、辱骂等行为。公安机关出具告诫书、法院签发人身安全保护令、医院就诊记录、轻微伤鉴定意见及邻居证言相互印证，形成完整证据链，足以认定被告存在家庭暴力事实。被告虽辩称系互殴或普通矛盾，但未提交有效反证，其抗辩不予采信。",
          "separation": "自2024年2月起双方分居，婚生子随原告生活至今，事实清楚。",
          "property_status": "涉案房产购于婚后，首付款中双方父母出资部分无明确约定仅赠与一方，依法推定为对夫妻双方的赠与；银行存款50万元及股票账户市值30万元均系婚姻关系存续期间的工资收入及投资收益，依法认定为夫妻共同财产。被告主张部分存款为婚前个人财产及股票为个人收益，因资金混同且举证不能，不予认定。"
        },
        "evidence_evaluation": {
          "adopted_evidence": [
            "e1, e2, e3, e4, e5, e6, e7, e8, e9, e10, e11, e12, e13, e14, e15"
          ],
          "partially_adopted_or_rejected_evidence": [
            "e18（父母出资凭证真实性认可，但证明目的不成立，依法推定为共同赠与）",
            "e19（婚前存款证明因资金混同且无法特定化，证明力不足，不予采信）"
          ],
          "evidence_chain_conclusion": "原告就家庭暴力、财产状况及抚养条件提交的证据来源合法、内容真实、与本案具有关联性，证明力达到高度盖然性标准，本院予以采信。"
        },
        "legal_reasoning": {
          "divorce_claim": "根据《民法典》第一千零七十九条，实施家庭暴力调解无效的，应当准予离婚。本案被告存在家暴行为，且双方已分居，夫妻感情确已破裂，无和好可能，原告离婚诉请依法应予支持。",
          "custody_and_support_claim": "根据《民法典》第一千零八十四条，离婚后子女抚养应以“最有利于未成年子女”为原则。婚生子现年4岁，原告自分居起实际抚养，生活环境稳定，且具备抚养能力。被告虽收入较高，但非决定抚养权的唯一因素。维持现有抚养状态更利于子女身心健康，故抚养权归原告。被告月收入1.5万元，原告主张每月3000元抚养费（约占其收入20%），符合《最高人民法院关于适用〈民法典〉婚姻家庭编的解释（一）》第四十九条规定，予以支持。",
          "property_division_claim": "根据《民法典》第一千零六十二条、第一千零八十七条，夫妻共同财产原则上均等分割。涉案房产净值120万元（现值200万-贷款80万），双方各享60万元份额；存款50万元、股票30万元各半分割。考虑到房产登记在被告名下且由被告实际使用，判归被告所有，剩余贷款由被告承担，被告需向原告支付房屋折价补偿款60万元。存款及股票折价款合计40万元由被告支付原告。被告共计需支付原告财产折价补偿款100万元。",
          "damages_claim": "根据《民法典》第一千零九十一条，因实施家庭暴力导致离婚的，无过错方有权请求损害赔偿。被告家暴行为对原告造成身心伤害，原告主张精神损害赔偿5万元，于法有据且数额适当，本院予以支持。"
        },
        "court_decision": {
          "divorce": "准予原告张某与被告李某离婚。",
          "custody_and_support": "婚生子李某某由原告张某直接抚养；被告李某自本判决生效之月起，每月15日前支付抚养费人民币3000元，至李某某年满十八周岁止。",
          "property_division": "位于某某市某某区某某路XX号房产归被告李某所有，该房产剩余按揭贷款80万元由被告李某负责偿还；被告李某于本判决生效之日起三十日内支付原告张某财产折价补偿款人民币100万元（含房屋折价款60万元、存款折价款25万元、股票折价款15万元）。",
          "damages": "被告李某于本判决生效之日起十日内支付原告张某精神损害赔偿金人民币50000元。",
          "court_costs": "案件受理费依法由双方各半负担。"
        },
        "applicable_laws": [
