      "case_id": "case-2024-marriage-0001",
      "裁判分析": {
        "事实认定与证据采信": {
          "婚姻关系": "双方于2018年10月18日登记结婚，婚姻关系合法有效，双方均无异议，予以确认。",
          "家庭暴力事实": "原告提交的公安机关告诫书、医院就诊记录、伤情鉴定意见书（轻微伤）、人身安全保护令裁定书及邻居证人证言形成完整证据链。被告虽抗辩系“双方互有肢体冲突”，但未能提供反证，且公安机关告诫书与法院保护令已对暴力危险作出初步司法认定。依法认定被告在婚姻存续期间多次实施家庭暴力，原告主张成立。",
          "分居事实": "原告自2024年2月起携子搬离并实际抚养子女，被告予以承认，分居事实清楚。",
          "财产性质认定": "涉案房产、银行存款、股票账户资金均取得于婚姻关系存续期间。被告主张父母出资15万元及婚前存款15万元属个人财产，但未能提供“明确只赠与一方”的书面约定，且婚前存款婚后与共同收入混同难以区分。依据《民法典》及相关司法解释，依法推定为夫妻共同财产。"
        },
        "争议焦点与裁判说理": {
          "焦点一_是否准予离婚": {
            "裁判结论": "准予离婚",
            "裁判理由": "《民法典》第1079条明确规定实施家庭暴力调解无效的应准予离婚。本案被告存在家暴行为，严重伤害夫妻感情，且双方已分居，调解和好无望，符合法定离婚条件。"
          },
          "焦点二_子女抚养权及抚养费": {
            "裁判结论": "抚养权归原告，被告每月支付抚养费3000元",
            "裁判理由": "婚生子现年4岁，原告自分居起实际承担主要抚养义务，生活环境稳定。依据“最有利于未成年子女”原则，变更抚养环境不利于孩子成长，故抚养权判归原告。被告月收入15000元，原告主张3000元/月（约占被告收入20%）符合《最高人民法院关于适用〈民法典〉婚姻家庭编的解释（一）》第49条规定的抚养费比例标准及当地实际生活水平，予以支持。"
          },
          "焦点三_夫妻共同财产分割": {
            "裁判结论": "依法均等分割，被告向原告支付折价补偿款100万元",
            "裁判理由": "房产现值200万元，扣除剩余贷款80万元，净值为120万元，双方各享60万元份额；存款50万元、股票30万元均属共同财产，各分得25万元与15万元。考虑到房产登记在被告名下且由被告实际使用，判归被告所有更为便利，剩余贷款由被告继续偿还。被告需就房产净值、存款、股票向原告支付合计100万元折价补偿。分割时已综合考量照顾女方及无过错方权益原则。"
          },
          "焦点四_离婚损害赔偿": {
            "裁判结论": "支持精神损害赔偿金5万元",
            "裁判理由": "被告实施家庭暴力构成《民法典》第1091条规定的法定过错情形。原告作为无过错方，身心受到伤害，有权请求损害赔偿。结合伤情鉴定（轻微伤）、家暴频次、过错程度及本地经济水平，原告诉请5万元在合理裁量范围内，予以全额支持。"
          }
        },
        "法律适用": [
          "《中华人民共和国民法典》第一千零七十九条（诉讼离婚及法定情形）",
          "《中华人民共和国民法典》第一千零八十四条（离婚后子女抚养）",
          "《中华人民共和国民法典》第一千零八十五条（抚养费负担）",
