            "双方自2024年2月起分居，婚生子随原告生活。"
          ],
          "争议事实及法院认定": {
            "家庭暴力事实": {
              "认定结果": "成立",
              "证据采信分析": "原告提交的公安机关告诫书、人身安全保护令裁定书、医院就诊记录、伤情鉴定意见书及证人证言已形成完整证据链。被告虽对证明目的提出异议，但未能提供反证推翻公安机关及法院已作出的初步认定。根据《反家庭暴力法》及民事诉讼高度盖然性证明标准，依法认定被告存在家庭暴力行为。",
              "质证意见回应": "被告主张系互殴及预防性措施不具终局性，但告诫书与保护令的作出已表明公权力机关对暴力行为的确认，被告抗辩不成立。"
            },
            "财产性质认定": {
              "认定结果": "均属夫妻共同财产",
              "证据采信分析": "房产购于婚后，双方父母出资部分无书面约定仅赠与一方，依《民法典婚姻家庭编解释（一）》第29条，推定为对夫妻双方的赠与。被告主张15万元存款为婚前财产，但资金已发生混同，被告未能完成特定化举证，依法认定为共同财产。股票系婚后以共同资金投资，收益依法属共同财产。",
              "质证意见回应": "被告提交的父母出资凭证及婚前存款证明真实性予以确认，但证明力不足以对抗法定共同财产推定规则。"
            }
          }
        },
        "争议焦点与法律适用分析": {
          "焦点一_是否准予离婚": {
            "法律适用": "《中华人民共和国民法典》第一千零七十九条",
            "裁判分析": "被告实施家庭暴力，且双方已分居，夫妻感情确已破裂。经法庭调解无效，符合法定离婚条件，依法应予准许。"
          },
          "焦点二_子女抚养权及抚养费": {
            "法律适用": "《中华人民共和国民法典》第一千零八十四条、第一千零八十五条",
            "裁判分析": "婚生子未满八周岁，法院依最有利于未成年子女原则裁判。原告自分居起实际抚养孩子，生活稳定，具备抚养能力。维持现有抚养状态有利于孩子身心健康。被告月收入15000元，原告主张3000元/月抚养费约占其月收入20%，符合司法解释规定的20%-30%比例区间，予以支持。"
          },
          "焦点三_夫妻共同财产分割": {
            "法律适用": "《中华人民共和国民法典》第一千零六十二条、第一千零八十七条",
            "裁判分析": "涉案房产净值120万元（200万-80万），存款及股票合计80万元，共同财产总额200万元。分割时应照顾子女、女方及无过错方权益。因被告存在家暴过错，酌定原告分得60%（120万元），被告分得40%（80万元）。房产登记在被告名下且由被告继续还贷更具操作性，判归被告所有，被告向原告支付相应折价补偿。"
          },
          "焦点四_离婚损害赔偿": {
            "法律适用": "《中华人民共和国民法典》第一千零九十一条",
            "裁判分析": "被告实施家庭暴力导致离婚，原告作为无过错方依法享有损害赔偿请求权。结合暴力频次、伤情程度（轻微伤）及当地生活水平，原告主张5万元精神损害赔偿金在合理裁量范围内，予以全额支持。"
          }
        },
        "裁判理由综合阐述": "本案系典型的因家庭暴力引发的离婚纠纷。法院审理离婚案件以夫妻感情是否确已破裂为裁判核心。原告提交的公文书证、鉴定意见及保护令裁定相互印证，足以认定被告存在家暴行为，该行为严重破坏夫妻信任基础，符合法定离婚事由。在子女抚养问题上，坚持‘儿童利益最大化’原则，原告长期实际照料孩子，判归原告抚养更符合未成年人成长需求。财产分割严格贯彻《民法典》照顾无过错方原则，对被告家暴行为予以否定性评价，在分割比例上向原告倾斜。精神损害赔偿系对家暴受害方的法定救济，依法应予支持。被告关于感情未破裂、财产属个人所有的抗辩缺乏事实与法律依据，不予采纳。",
        "模拟判决主文": [
